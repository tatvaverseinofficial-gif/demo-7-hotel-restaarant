# Supabase Configuration (required for full edit mode)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Site Configuration
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_HOTEL_NAME=Grand Imperial Palace
NEXT_PUBLIC_HOTEL_PHONE=1111111111
NEXT_PUBLIC_HOTEL_EMAIL=reservations@grandimperialpalace.com

# Admin Auth — SERVER ONLY (set in .env.local, never commit real values)
ADMIN_USERNAME=
ADMIN_PASSWORD=
ADMIN_SESSION_SECRET=

# Demo mode: true = view-only admin (no edits/uploads). false + Supabase = full edit mode.
NEXT_PUBLIC_DEMO_MODE=true
